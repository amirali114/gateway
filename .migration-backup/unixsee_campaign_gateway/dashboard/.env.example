# Dashboard authentication and RBAC
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USER_STORE_PATH=/var/lib/unixsee-gateway/dashboard
DASHBOARD_BOOTSTRAP_ADMIN_USERNAME=admin
DASHBOARD_BOOTSTRAP_ADMIN_PASSWORD_HASH=$2b$12$replace-with-generated-bcrypt-hash
DASHBOARD_BOOTSTRAP_ADMIN_EMAIL=
DASHBOARD_SESSION_SECRET=change-me-long-random-secret-at-least-32-chars
DASHBOARD_PUBLIC_BASE_URL=https://panel.example.com
DASHBOARD_TRUST_PROXY=true

# Backward-compatible bootstrap aliases from R9.4; prefer DASHBOARD_BOOTSTRAP_* above.
# DASHBOARD_ADMIN_USERNAME=admin
# DASHBOARD_ADMIN_PASSWORD_HASH=$2b$12$replace-with-generated-bcrypt-hash

# Mother server-side API access. Never expose this to browser/client code.
UNIXSEE_MOTHER_BASE_URL=http://127.0.0.1:8732
UNIXSEE_MOTHER_MANAGEMENT_TOKEN=change-me

# Optional R9.9 Dashboard user/audit storage profile.
# JSON remains the supported default in this release. PostgreSQL profile is documented for later driver-enabled production builds.
DASHBOARD_USER_STORE_ENGINE=json
# DASHBOARD_POSTGRES_DSN=postgres://uxgw_dashboard:change-me@postgres.example.internal:5432/uxgw_dashboard?sslmode=require
