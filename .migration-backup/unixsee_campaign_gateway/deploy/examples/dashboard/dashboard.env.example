# Copy to /etc/unixsee-gateway/dashboard.env and chmod 0640.
UNIXSEE_MOTHER_BASE_URL=http://127.0.0.1:8732
UNIXSEE_DASHBOARD_BIND_HOST=127.0.0.1
UNIXSEE_DASHBOARD_PORT=8740
UNIXSEE_DASHBOARD_USER_STORE=/var/lib/unixsee-gateway/dashboard/users.json
DASHBOARD_SESSION_SECRET=replace-with-long-random-secret
DASHBOARD_BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
DASHBOARD_BOOTSTRAP_ADMIN_PASSWORD_HASH=replace-with-hash-from-dashboard-script
# Server-side only. Never expose to browser.
UNIXSEE_MOTHER_MANAGEMENT_TOKEN=replace-with-token-or-read-from-file-wrapper
