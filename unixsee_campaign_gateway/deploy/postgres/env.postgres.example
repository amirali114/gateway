# Mother PostgreSQL profile. Store in /etc/unixsee-campaign-gateway/mother.env with 0640 permissions.
UNIXSEE_MOTHER_POSTGRES_DSN=postgres://unixsee_gateway:change-me@127.0.0.1:5432/unixsee_gateway?sslmode=require

# Optional future dashboard PostgreSQL profile. JSON user store remains default in R9.9 offline build.
DASHBOARD_USER_STORE_ENGINE=json
# DASHBOARD_POSTGRES_DSN=postgres://unixsee_dashboard:change-me@127.0.0.1:5432/unixsee_dashboard?sslmode=require
